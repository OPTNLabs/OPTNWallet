{
  "name": "optn-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "addons:validate": "vitest run src/services/addons/__tests__/BuiltinManifestValidation.test.ts",
    "typecheck": "tsc -b",
    "typecheck:core": "tsc -p tsconfig.core.json --noEmit",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:core": "eslint src --ext ts,tsx --ignore-pattern 'src/pages/apps/**' --report-unused-disable-directives --max-warnings 0",
    "ci:core": "npm run lint:core && npm run typecheck:core && npm run test -- --run && npm run build",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "capacitor:init": "npx cap init",
    "capacitor:add:android": "npx cap add android",
    "capacitor:add:ios": "npx cap add ios",
    "capacitor:copy": "npx cap copy",
    "capacitor:sync": "npx cap sync",
    "capacitor:sync:android": "npx cap sync android",
    "capacitor:sync:ios": "npx cap sync ios",
    "capacitor:open:android": "npx cap open android",
    "capacitor:open:ios": "npx cap open ios",
    "serve": "npx serve -s dist",
    "android:prepare": "dotenv -e .env -- npm run build && npm run capacitor:sync:android",
    "android:apk:dev": "npm run android:prepare && cd android && ./gradlew assembleDebug",
    "android:apk:dev:install": "npm run android:apk:dev && adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:apk:prod": "npm run android:prepare && cd android && ./gradlew assembleRelease",
    "android:aab:prod": "npm run android:prepare && cd android && ./gradlew bundleRelease",
    "build:aab": "npm run android:aab:prod"
  },
  "dependencies": {
    "@bitauth/libauth": "^3.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/barcode-scanner": "^2.0.3",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/clipboard": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/dialog": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.3",
    "@capacitor/toast": "^7.0.0",
    "@cashscript/utils": "^0.9.3",
    "@electrum-cash/network": "^4.1.3",
    "@electrum-cash/web-socket": "^1.0.0",
    "@reduxjs/toolkit": "^2.2.5",
    "@reown/walletkit": "^1.2.3",
    "@types/sql.js": "^1.4.9",
    "@walletconnect/core": "^2.19.2",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.19.2",
    "@walletconnect/utils": "^2.19.2",
    "axios": "^1.7.7",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "cashc": "^0.9.3",
    "cashscript": "^0.11.2",
    "decimal.js": "^10.4.3",
    "delay": "^6.0.0",
    "dotenv": "^16.4.7",
    "ecpair": "^2.1.0",
    "idb-keyval": "^6.2.1",
    "localforage": "^1.10.0",
    "luxon": "^3.6.1",
    "path": "^0.12.7",
    "qrcode.react": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-icons": "^5.4.0",
    "react-loader-spinner": "^6.1.6",
    "react-multi-carousel": "^2.8.5",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.23.0",
    "react-tooltip": "^5.29.1",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^3.1.0",
    "sql.js": "^1.10.3",
    "tiny-secp256k1": "^2.2.3",
    "ts-node": "^10.9.2",
    "url": "^0.11.3",
    "vite-plugin-top-level-await": "^1.4.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.19",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsqr": "^1.4.0",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vitest": "^3.2.4"
  }
}
