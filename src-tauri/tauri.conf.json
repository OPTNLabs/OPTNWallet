{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OPTNWallet",
  "version": "1.6.2",
  "identifier": "com.optilabs.wallet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite --config vite.desktop.config.ts --host",
    "beforeBuildCommand": "npx vite build --config vite.desktop.config.ts"
  },
  "app": {
    "windows": [
      {
        "title": "OPTN Wallet",
        "width": 420,
        "height": 820,
        "minWidth": 380,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
