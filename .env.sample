KEYSTORE_PATH=xxxxx
KEYSTORE_PASS=xxxxx
KEYSTORE_ALIAS=xxxxx
KEYSTORE_ALIAS_PASS=xxxxx
# Price server base URL (optional override)
VITE_PRICE_SERVER_BASE=https://price.optnlabs.com
VITE_WC_PROJECT_ID=xxxxx

# Optional infra endpoint overrides (CSV lists for failover)
# Global lists:
# VITE_ELECTRUM_SERVERS=host1,host2,wss://host3:50004
# VITE_CHAINGRAPH_URLS=https://cg1/v1/graphql,https://cg2/v1/graphql
# VITE_BCMR_API_BASE_URLS=https://bcmr1/api,https://bcmr2/api
# Example chipnet override:
# VITE_BCMR_API_BASE_URLS_CHIPNET=https://bcmr-chipnet.paytaca.com/api
# VITE_IPFS_GATEWAYS=https://ipfs.io/ipfs,https://dweb.link/ipfs
# Optional Quantumroot chipnet consensus fallback for local dev/test only.
# Mobile APK builds should rely on Fulcrum endpoints and not this SSH/BCHN path.
# VITE_QUANTUMROOT_BCHN_SSH_TARGET=lightswarm@192.168.31.218
# VITE_QUANTUMROOT_BCHN_CONTAINER_NAME=bch-chipnet
# VITE_QUANTUMROOT_BCHN_BITCOIN_CLI_CONF=/data/bitcoin.conf
#
# Network-specific lists (override globals):
# VITE_ELECTRUM_SERVERS_MAINNET=...
# VITE_ELECTRUM_SERVERS_CHIPNET=...
# VITE_CHAINGRAPH_URLS_MAINNET=...
# VITE_CHAINGRAPH_URLS_CHIPNET=...
# VITE_BCMR_API_BASE_URLS_MAINNET=...
# VITE_BCMR_API_BASE_URLS_CHIPNET=...

# ParyonUSD deployment config
# Mainnet defaults already match the verified live deployment bundle.
# Override only if you are targeting a different ParyonUSD network/config.
# VITE_PARYON_MAINNET_ORACLE_PUBLIC_KEY=...
# VITE_PARYON_MAINNET_PROTOCOL_FEE_LOCKING_BYTECODE=...
# VITE_PARYON_MAINNET_START_BLOCK_HEIGHT=...
# VITE_PARYON_MAINNET_PERIOD_LENGTH_BLOCKS=144
# VITE_PARYON_MAINNET_TIME_LOCK_REDEMPTION=12
# VITE_PARYON_MAINNET_PARYON_TOKEN_ID=...
# VITE_PARYON_MAINNET_POOL_TOKEN_ID=...
# VITE_PARYON_MAINNET_REDEEMER_TOKEN_ID=...
# VITE_PARYON_MAINNET_LOAN_KEY_FACTORY_TOKEN_ID=...
# VITE_PARYON_MAINNET_ORACLE_MIGRATION_KEY_TOKEN_ID=...
# VITE_PARYON_CHIPNET_ORACLE_PUBLIC_KEY=...
# VITE_PARYON_CHIPNET_PROTOCOL_FEE_LOCKING_BYTECODE=...
# VITE_PARYON_CHIPNET_START_BLOCK_HEIGHT=...
# VITE_PARYON_CHIPNET_PERIOD_LENGTH_BLOCKS=144
# VITE_PARYON_CHIPNET_TIME_LOCK_REDEMPTION=12
# VITE_PARYON_CHIPNET_PARYON_TOKEN_ID=...
# VITE_PARYON_CHIPNET_POOL_TOKEN_ID=...
# VITE_PARYON_CHIPNET_REDEEMER_TOKEN_ID=...
# VITE_PARYON_CHIPNET_LOAN_KEY_FACTORY_TOKEN_ID=...
# VITE_PARYON_CHIPNET_ORACLE_MIGRATION_KEY_TOKEN_ID=...
